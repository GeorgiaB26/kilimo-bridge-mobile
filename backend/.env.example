# Kilimo Bridge — Security & Environment Configuration
# Copy to .env and set production values

NODE_ENV=development
PORT=3001

# JWT signing secret — generate with: openssl rand -hex 64
JWT_SECRET=change-this-in-production

# AES-256 field encryption key — generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-this-32-char-encryption-key!

# Backup encryption
BACKUP_ENCRYPTION_KEY=change-this-backup-key

# Equity Bank H2H Integration
EQUITY_H2H_URL=https://api.equitybank.co.ke/h2h/v1
EQUITY_API_KEY=
EQUITY_WEBHOOK_SECRET=
EQUITY_TIMEOUT_MS=30000

# Payment workflow
USE_EQUITY_H2H=false
REQUIRE_PAYMENT_VERIFICATION=false

# Database
DATABASE_PATH=./data/kilimo.db

# Production domains (after you register kilimobridge.co.ug or similar)
APP_URL=https://app.kilimobridge.co.ug
API_URL=https://api.kilimobridge.co.ug
# Comma-separated browser origins allowed to call the API
CORS_ORIGINS=https://app.kilimobridge.co.ug,https://admin.kilimobridge.co.ug

# Pre-SMS pilot: keep OTP as 123456 until banking + SMS are live
PILOT_OTP=true
